# ASTY Blog Agent — Lean Edition env
# Monthly budget: <$10 (expected: $3-$5)
# NEVER commit .env to git.

# --- Anthropic ---
# Default model: claude-haiku-4-5 (hardcoded in agents)
# Set a spend limit at: https://console.anthropic.com/settings/limits
ANTHROPIC_API_KEY=sk-ant-...

# --- DeepL (Free tier — 500k chars/month) ---
DEEPL_API_KEY=...:fx

# Run `npx tsx scripts/setup-glossaries.ts` once to generate these
DEEPL_GLOSSARY_JA_ID=
DEEPL_GLOSSARY_ZH_ID=

# DeepL cost guards
DEEPL_MAX_CHARS_PER_RUN=40000
DEEPL_MAX_CHARS_MONTHLY=450000

# --- Unsplash (Free tier) ---
UNSPLASH_ACCESS_KEY=

# --- ASTY Cabin site ---
ASTY_SITE_URL=https://asty-cabin-check.vercel.app
ASTY_AGENT_API_KEY=
