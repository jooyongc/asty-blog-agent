# Dashboard login password (set a strong value)
DASHBOARD_PASSWORD=change-me

# Session secret (generate with: openssl rand -hex 32)
DASHBOARD_SESSION_SECRET=change-me

# Per-site bearer tokens for calling each site's admin export APIs.
# Variable name must match the `env.api_key` field of each sites/<id>/config.json.
ASTY_AGENT_API_KEY=...

# Optional: Anthropic usage readout, DeepL key for local usage file
DEEPL_API_KEY=...
